    {
      "name": "Sessions",
      "item": [
        {
          "name": "Create Session (Login)",
          "event": [
            {
              "listen": "test",
              "script": {
                "id": "dba9ed3f-af3e-4a53-bf74-6b5691e0ba0b",
                "exec": [
                  "pm.test('status is 2xx', function () {",
                  "  pm.expect(pm.response.code).to.be.within(200, 299);",
                  "});",
                  "pm.test('response time < 1000ms', function () {",
                  "  pm.expect(pm.response.responseTime).to.be.below(1000);",
                  "});",
                  "const json = pm.response.json();",
                  "if (json.access_token) {",
                  "  pm.collectionVariables.set('token', json.access_token);",
                  "}",
                  "if (json.refresh_token) {",
                  "  pm.collectionVariables.set('refreshToken', json.refresh_token);",
                  "}",
                  "if (json.user && json.user.id) {",
                  "  pm.collectionVariables.set('userId', json.user.id);",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
